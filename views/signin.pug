extends layout

block content
  section.container
    section.left-column
    section.center-column
      h1.page-title= title
      
      if successMessage
        .message.success-message= successMessage
      
      if errorMessages && errorMessages.length > 0
        .error-messages
          each error in errorMessages
            p.error-message= error

      form.signin-form(action="/users/signin", method="POST")
        .form-group
          label(for="email") Email
          input(type="email", id="email", name="email", value=email)
        
        .form-group
          label(for="password") Password
          input(type="password", id="password", name="password")
        .form-group
          button.submit-bttn(type="submit") Sign In
          a.reset-link(href="/users/request-reset") Forgot Password
    section.right-column